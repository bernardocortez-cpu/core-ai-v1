{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://core-backend-w4g6.onrender.com/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://core-backend-w4g6.onrender.com/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

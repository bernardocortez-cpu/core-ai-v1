}

/* bolha */
.icon-btn::after{
  content: attr(data-tip);
  position: absolute;
  left: 50%;
  bottom: calc(100% + 10px);
  transform: translateX(-50%) translateY(2px);

    background: #ffffff;                 /* ðŸ”¥ branco */
  color: #000000;                      /* ðŸ”¥ texto preto */

/* ================================
   CHIPS TOGGLE (Web Search / Reasoning)
   - Ativo: borda branca persistente
   - Sem mudar cor de Ã­cone/texto
   - Sem focus ring
================================ */

/* Base: mantÃ©m as cores suaves (nÃ£o mexe no interior quando ativa) */
.chip{
  color: rgba(255,255,255,0.78) !important;
  background: rgba(18,18,20,0.9) !important;
  border: 1px solid rgba(255,255,255,0.174) !important;
}

/* Ãcone: forÃ§a a ter o mesmo tom sempre (nÃ£o â€œfica brancoâ€ ao ativar) */
.chip .chip-ico{
  color: rgba(255,255,255,0.78) !important;
}
.chip .chip-ico svg{
  fill: none !important;          /* âœ… nÃ£o pinta por dentro */
  stroke: currentColor !important; /* âœ… mantÃ©m outline */
}

/* Hover: podes manter o hover (sem mexer no interior de forma agressiva) */
.chip:hover{
  background: rgba(28,28,30,1) !important;
  border-color: rgba(255,255,255,0.14) !important;
}

/* âœ… Ativo: SÃ“ borda branca (e opcionalmente um micro brilho), sem mudar texto/Ã­cone */
.chip.chip-active{
  border-color: rgba(255,255,255,0.75) !important;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.18) !important; /* opcional, fica premium */
  /* NÃƒO meter color aqui */
}

/* Remove outline/ring (fica limpo) */
.chip:focus,
.chip:focus-visible,
.chip:active{
  outline: none !important;
  box-shadow: none !important;
}

/* Mas quando estÃ¡ ativo, mantÃ©m a borda mesmo com focus */
.chip.chip-active:focus,
.chip.chip-active:focus-visible,
.chip.chip-active:active{
  outline: none !important;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.18) !important;
}

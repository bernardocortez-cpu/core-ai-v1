/* ===========================
   CHIP BUTTON — RESET TOTAL
   =========================== */

button.chip {
  appearance: none;
  -webkit-appearance: none;

  border: none !important;
  outline: none !important;
  box-shadow: none !important;

  background: transparent !important;

  padding: 6px 10px;
  margin-left: -10px;
  border-radius: 999px;

  display: inline-flex;
  align-items: center;
  gap: 6px;

  font-size: 13.5px;
  font-weight: 400;
  line-height: 1;

  color: rgba(226, 226, 226, 0.521);
  cursor: pointer;
}

/* hover subtil (não botão visual) */
button.chip:hover {
  color: #ffffff;
  background: transparent;
}

/* ativo */
button.chip.chip-active {
  color: #ffffff;
}

/* remove focus ring invisível */
button.chip:focus,
button.chip:focus-visible {
  outline: none !important;
  box-shadow: none !important;
}
/* impedir que o composer crie contornos visuais APENAS nos chips (não afetar send/model) */
.composer-bottom .chip,
.composer-bottom .composer-attach{
  border: none;
  background: transparent;
  box-shadow: none;
}



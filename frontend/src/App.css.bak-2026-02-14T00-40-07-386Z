html,
body,
#root {
  height: 100%;
  margin: 0;
  padding: 0;
  background-color: var(--bg);
  color: var(--text);
  font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
    "Segoe UI", sans-serif;
}
.app {
  display: flex;
  height: 100vh;
}
.app{
  --sidebar-w: 260px; /* largura normal da sidebar */
}
/* ===================== SIDEBAR ===================== */
.sidebar {
  width: 260px;
  background-color: #0b0b0d;
  border-right: 1px solid #1f1f23;
  padding: 20px 14px 16px;
  display: flex;
  flex-direction: column;
  position: relative;
}
/* linha fina de â€œcore energyâ€ */
.sidebar::after{
  content:"";
  position:absolute;
  top:0;
  right:-1px;
  width:1px;
  height:100%;
  background: linear-gradient(to bottom,
    rgba(48,213,200,0.0),
    rgba(48,213,200,0.0)
  );
  pointer-events:none;
}
.sidebar-logo{
  width: 105px;
  height: auto;
  display: block;
  margin: 0px 0 -3px 2px;   /* ðŸ‘ˆ puxa para a esquerda */
  object-fit: contain;

  mix-blend-mode: screen;
  filter: 
    drop-shadow(0 6px 18px rgba(0,0,0,0.6))
    contrast(1.05);

  opacity: 0.95;
}
.sidebar-header {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 18px;
  flex-shrink: 0;
}

.logo-title {
  margin: 0;
  font-size: 19px;
  font-weight: 600;
  letter-spacing: 0.2px;
  color: #f5f5f7;
  line-height: 1.2;
  font-family: "Inter", system-ui, -apple-system, "SF Pro Display", sans-serif;
}

.logo-sub {
  font-size: 11px;
  opacity: 0.7;
  line-height: 0;
}

/* NAV */
.nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
  flex-shrink: 0;
  margin-bottom: 14px;
}

.nav-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.nav-section {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #ffffff;
  opacity: 0.6;
}


.nav-btn {
  text-align: left;
  padding: 8px 10px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: #c9c7c7;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, transform 0.08s;
}

.nav-btn:hover {
  background-color: rgba(255,255,255,0.05);
  color: #f5f5f7;
  transform: translateY(-0.5px);
}

.nav-btn.active {
  background-color: rgba(255,255,255,0.06);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 8px 18px rgba(0,0,0,0.35);
}
/* Ã­cone da sidebar (estilo ChatGPT) */
.nav-btn {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* wrapper do Ã­cone */
.nav-ico {
  width: 18px;
  height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af; /* cinza ChatGPT */
  flex-shrink: 0;
}

/* svg do Ã­cone */
.nav-ico svg {
  width: 18px;
  height: 18px;
  stroke-width: 1.8;
}

/* quando ativo */
.nav-btn.active .nav-ico {
  color: #ffffff;
}

/* Chats zone */
.sidebar-chats {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.new-chat-btn {
  width: 100%;
  border-radius: 999px;
  border: none;
  background-color: #ffffff;        /* branco */
  color: #000000;                   /* texto preto */
  font-size: 14px;
  padding: 8px 12px;
  text-align: left;
  cursor: pointer;
  font-weight: 500;
  transition: 
    background 0.15s ease,
    transform 0.1s ease,
    box-shadow 0.1s ease;
}

.new-chat-btn:hover {
  background-color: #f2f2f2;
  transform: translateY(-1px);
  box-shadow: 0 6px 14px rgba(0,0,0,0.35);
}

.chat-list-section {
  display: flex;
  flex-direction: column;
  margin-top: 14px;
  flex: 1;
  min-height: 0;
}

.chat-list {
  margin-top: 6px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-right: 4px;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  position: relative; /* ðŸ”¥ ancora menus */
  scrollbar-width: thin;
  scrollbar-color: #4b4b4d transparent;
}

.chat-list::-webkit-scrollbar {
  width: 6px;
}
.chat-list::-webkit-scrollbar-track {
  background: transparent;
}
.chat-list::-webkit-scrollbar-thumb {
  background: #3a3a3c;
  border-radius: 999px;
}
.chat-list:hover::-webkit-scrollbar-thumb {
  background: #4b4b4d;
}

.chat-list-item-wrapper {
  position: relative;
  overflow: visible; /* ðŸ”¥ PERMITE O MENU SAIR */
}

.chat-list-item {
  width: 100%;
  box-sizing: border-box;
  border: none;
  background: transparent;
  color: #d1d1d3;
  font-size: 13px;
  text-align: left;
  padding: 7px 8px;
  border-radius: 8px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  transition: background 0.15s, color 0.15s;
}

.chat-list-item:hover {
  background-color: #2c2c2e;
}

.chat-list-item.active,
.chat-list-item-wrapper.active .chat-list-item {
  background-color: #2c2c2e;
  color: #ffffff;
}

.chat-list-title {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.chat-list-title-row{
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
  flex: 1;
}

.chat-list-title{
  flex: 1;
  min-width: 0;
}

.chat-pin-icon{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;

  color: rgba(255, 255, 255, 0.614);
  opacity: 0.95;
}

.chat-pin-svg{
  display: block;

  /* vira o pin para o outro lado */
  transform: scaleX(-1) rotate(-42deg);
}

.chat-list-item.active .chat-pin-icon{
  color: #ffffff;
}

.chat-list-item.active .chat-pin-icon{
  color: #ffffff;
}

/* "..." */
.chat-more-btn {
  width: 24px;
  height: 24px;

  display: flex;              /* ðŸ”¥ */
  align-items: center;        /* ðŸ”¥ centra vertical */
  justify-content: center;    /* ðŸ”¥ centra horizontal */

  border: none;
  background: transparent;
  color: #8e8e93;
  font-size: 18px;
  line-height: 1;             /* ðŸ”¥ evita empurrÃµes */
  padding: 0;
  border-radius: 6px;
  cursor: pointer;

  opacity: 0;
  transition: background 0.15s, opacity 0.15s, color 0.15s;
}

.chat-list-item:hover .chat-more-btn {
  opacity: 1;
}

.chat-more-btn:hover {
  background-color: #3a3a3c;
  color: #ffffff;
}

/* Menu */
.chat-menu-backdrop {
  position: fixed;
  inset: 0;
  z-index: 15;
}

.chat-menu {
  position: absolute;
  margin-top: -10px;
  top: 6px;
  right: 6px;
  background-color: #0f0f0f;
  border-radius: 8px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
  padding: 4px 0;
  z-index: 20;
  min-width: 140px;
  border: 1px solid #1f1f1f;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.chat-menu.open-up {
  top: auto;
  bottom: 4px;
}

.chat-menu button {
  width: 100%;
  border: none;
  background: transparent;

  display: flex;
  align-items: center;
  gap: 9px;

  padding: 9px 12px;
  text-align: left;
  cursor: pointer;

  color: #e5e5e7;
  font-size: 13px;
}
/* Ã­cones do menu da conversa */
.chat-menu .menu-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  opacity: 0.9;
}

/* texto do menu */
.chat-menu span {
  line-height: 1;
}

/* hover */
.chat-menu button:hover {
  background-color: #1a1a1a;
}

/* apagar */
.chat-menu button.danger {
  color: #ff453a;
}

.chat-menu button.danger:hover {
  background-color: rgba(255, 69, 58, 0.12);
}

.chat-menu button:hover {
  background-color: #1a1a1a;
}

.chat-menu button.danger {
  color: #ff453a;
}

/* Footer user */
.sidebar-footer {
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px solid #2c2c2e;
  flex-shrink: 0;
}

.user-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 11px;
  border-radius: 12px;
  background-color: #1a1a1a;
  border: 1px solid #2c2c2e;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.45);
}

.user-avatar {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: radial-gradient(circle at 30% 20%, #122658);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 0px;
  min-width: 0;
}

.user-name {
  font-size: 13px;
  color: #e5e5e7;
  font-weight: 500;
}

.user-plan {
  font-size: 11px;
  color: #a1a1a5;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

/* ===================== MAIN AREA (FULL WIDTH) ===================== */

.chat-area {
  flex: 1;
  min-width: 0; /* IMPORTANT: deixa o conteÃºdo esticar sem rebentar */
  display: flex;
  flex-direction: column;
  background-color: #000000;
  overflow: hidden;
}

/* Top bar */
.top-bar {
  height: 52px;
  border-bottom: 1px solid var(--stroke);
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background:
    radial-gradient(800px 80px at 40% 0%, rgba(48,213,200,0.12), transparent 60%),
    var(--bg);
  flex-shrink: 0;
}

.top-left-title {
  display: flex;
  align-items: baseline;
  font-family: "Inter", system-ui, sans-serif;
  font-size: 15px;
}

.top-left-title .welcome-light {
  font-weight: 400;
  margin-right: 4px;
  color: #ffffff;
  opacity: 0.6;
}

.top-left-title strong {
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.3px;
}

.plan-pill {
  font-size: 12px;
  border-radius: 999px;
  padding: 5px 12px;
  background: rgba(255,255,255,0.06);
  color: #d1d1d3;
  border: 1px solid rgba(190, 190, 190, 0.2);
}

/* ===================== CHAT ===================== */

.chat-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-main-body {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 18px 24px 0;

  overflow-y: auto;           /* ðŸ”¥ scroll aqui */
  scrollbar-width: thin;      /* Firefox */
  scrollbar-color: #3a3a3c transparent;
}

/* Messages */
.messages{
  flex: 1;
  overflow: visible;
  padding: 12px 0 10px;

  display: flex;
  flex-direction: column;
  gap: 14px;

  /* âœ… mesma largura do composer */
  width: min(780px, calc(100vw - 340px));
  margin: 0 auto; /* mantÃ©m centrado */
  box-sizing: border-box;
}

.messages::-webkit-scrollbar {
  width: 8px;
}
.messages::-webkit-scrollbar-track {
  background: transparent;
}
.messages::-webkit-scrollbar-thumb {
  background: #3a3a3c;
  border-radius: 999px;
}
.messages:hover::-webkit-scrollbar-thumb {
  background: #4b4b4d;
}

.msg {
  max-width: 100%;
  font-size: 14px;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

.msg-ai{
  align-self: flex-start;
  color: #e5e5e7;
  background: transparent;
  padding: 10px 0;

  /* âœ… ligeiro shift para a esquerda */
  padding-right: 56px;
}

/* Markdown rendering (assistant) */
.msg-ai .md {
  white-space: normal;
}
.msg-ai .md p {
  margin: 0 0 10px;
}
.msg-ai .md p:last-child {
  margin-bottom: 0;
}
.msg-ai .md h1,
.msg-ai .md h2,
.msg-ai .md h3 {
  margin: 16px 0 8px;
  line-height: 1.25;
  font-weight: 700;
}
.msg-ai .md h1 { font-size: 18px; }
.msg-ai .md h2 { font-size: 16px; }
.msg-ai .md h3 { font-size: 15px; }
.msg-ai .md ul,
.msg-ai .md ol {
  margin: 0 0 10px 18px;
  padding: 0;
}
.msg-ai .md li { margin: 4px 0; }
.msg-ai .md table {
  width: 100%;
  border-collapse: collapse;
  margin: 10px 0;
  font-size: 13px;
}
.msg-ai .md th,
.msg-ai .md td {
  border: 1px solid rgba(255,255,255,0.12);
  padding: 8px 10px;
  vertical-align: top;
}
.msg-ai .md th {
  background: rgba(255,255,255,0.06);
  font-weight: 600;
}
.msg-ai .md pre {
  margin: 10px 0;
  padding: 12px 14px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 12px;
  overflow: auto;
}
.msg-ai .md code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.msg-ai .md-code-inline {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 8px;
  padding: 2px 6px;
}
.msg-ai .md-code-block {
  background: transparent;
  border: 0;
  padding: 0;
}
.msg-ai .md blockquote {
  margin: 10px 0;
  padding: 6px 12px;
  border-left: 3px solid rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.03);
  color: rgba(229,229,231,0.9);
}
.msg-ai .md a {
  color: #93c5fd;
  text-decoration: underline;
}
.msg-ai .md hr {
  border: 0;
  height: 1px;
  background: rgba(255, 255, 255, 0.12);
  margin: 14px 0;
}

/* MathJax (LaTeX) */
.msg-ai .md mjx-container {
  max-width: 100%;
}
.msg-ai .md mjx-container[display="true"] {
  display: block;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 6px 0;
}

.msg-user{
  align-self: flex-end;

  /* âœ… ligeiro shift para a direita */
  margin-left: 56px;

  max-width: 420px;
  width: fit-content;

  padding: 8px 12px;
  border-radius: 14px;

  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(214, 214, 214, 0.12);
  color: #ffffff;
}
.thinking {
  font-size: 12px;
  opacity: 0.7;
  padding: 6px 0;
}

/* Empty state */
.chat-empty-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-empty-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  margin-top: -40px;
}

.chat-empty-title {
  font-size: 2.35rem;
  font-weight: 400;
  color: #f9fafb;
  margin-top: 0px;
  letter-spacing: 0.1px;
}

.chat-empty-subtitle {
  font-size: 1.15rem;
  font-weight: 300;
  color: #9ca3af;
  letter-spacing: 0.3px;
  font-family: "Inter", system-ui, sans-serif;
  margin-bottom: -6px;
}

/* ===================== INPUT (FULL WIDTH) ===================== */

.chat-input-wrapper {
  position: sticky;
  bottom: 0;
  width: 100%;
  background: linear-gradient(to top, #000000 80%, transparent);
  padding: 16px 0 35px;
  flex-shrink: 0;
}

/* ðŸ‘‡ IMPORTANT: sem max-width para ocupar toda a direita */
/* CENTRADO */
.chat-input-form{
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* caixa do composer */
.composer{
  width: min(780px, calc(100vw - 340px));
  background: rgba(20,20,22,0.55);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 18px;
  box-shadow: 0 16px 50px rgba(0,0,0,0.65);
  backdrop-filter: blur(10px);
  padding: 7.5px 10px;
}

/* topo: textarea + send */
.composer-top{
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: stretch;
}
/* ===================== TEXTAREA (auto-grow + scroll bonito) ===================== */
.composer-textarea{
  width: 100%;
  box-sizing: border-box;

  min-height: 74px;
  max-height: 220px;              /* ðŸ‘ˆ limite do crescimento */
  overflow-y: auto;               /* ðŸ‘ˆ scroll sÃ³ depois do limite */
  resize: none;

  background: transparent;        /* ðŸ‘ˆ fica â€œintegradoâ€ no composer */
  border: none;                   /* ðŸ‘ˆ remove borda feia default */
  outline: none;                  /* ðŸ‘ˆ sem focus feio */
  color: rgba(255,255,255,0.92);
  font: inherit;
  font-size: 14px;
  line-height: 1.45;

  padding: 10px 10px;             /* ðŸ‘ˆ isto resolve 80% do â€œmauâ€ */
}

/* Scroll do textarea (fino e clean) */
.composer-textarea{
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.22) transparent;
}
.composer-textarea::-webkit-scrollbar{ width: 6px; }
.composer-textarea::-webkit-scrollbar-track{ background: transparent; }
.composer-textarea::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.16);
  border-radius: 999px;
}
.composer-textarea:hover::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.26);
}

.composer-textarea::placeholder{
  color: rgba(255,255,255,0.42);
  font-weight: 400;
  letter-spacing: 0.2px;
}

.composer-textarea::-webkit-scrollbar{
  width: 6px;
}
.composer-textarea::-webkit-scrollbar-track{
  background: transparent;
}
.composer-textarea::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.16);
  border-radius: 999px;
}
.composer-textarea:hover::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.26);
}

.composer-textarea::placeholder{
  color: rgba(255,255,255,0.42);
  font-weight: 400;
  letter-spacing: 0.2px;
}

/* botÃ£o enviar */
/* botÃ£o enviar â€” estilo ChatbotAI */
.composer-send{
  width: 40px;
  height: 40px;
  border-radius: 999px;
  border: none;
  background: #ffffff;               /* ðŸ”¥ branco */
  color: #000000;                    /* ðŸ”¥ seta preta */
  cursor: pointer;
  display: grid;
  place-items: center;
  padding: 0;
  line-height: 0;
  transition: 
    transform 0.08s ease,
    background 0.15s ease,
    box-shadow 0.15s ease;
  box-shadow: 0 6px 14px rgba(0,0,0,0.35);
}

/* Ã­cone */
.composer-send svg{
  display: block;
  transform: translateY(-1px); /* ligeiramente para cima como no original */
}

/* hover */
.composer-send:hover{
  background: #f2f2f2;
  transform: translateY(-1px);
}

/* disabled */
.composer-send:disabled{
  background: #d6d6d6;
  color: #555;
  box-shadow: none;
  cursor: default;
}
.composer-attach{
  width: 34px;
  height: 34px;
  border-radius: 10px;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  cursor: pointer;
  flex-shrink: 0;

  background: transparent;
  border: none;
  color: rgba(255,255,255,0.78);

  padding: 0;
  line-height: 0;

  transition:
    background 0.15s ease,
    transform 0.08s ease,
    color 0.15s ease;
}

.composer-attach:hover{
  background: rgba(255,255,255,0.06);
  transform: translateY(-1px);
  color: rgba(255,255,255,0.92);
}

.composer-file{
  display:none;
}

/* chips */
.composer-bottom{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 6px 3px;
}

/* grupo esquerdo (upload + chips) */
.composer-bottom > :not(.composer-send-bottom){
  flex-shrink: 0;
}

/* botÃ£o enviar Ã  direita */
.composer-send-bottom{
  margin-left: auto; /* ðŸ”¥ isto empurra para a direita */
}

.chip{
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 38px;
  padding: 0 11.5px;
  border-radius: 999px;
  cursor: pointer;

  background: rgba(18,18,20,0.9);
  border: none;
  color: rgba(255,255,255,0.78);
  font-size: 12px;

  transition:
    background 0.15s ease,
    color 0.15s ease,
    transform 0.08s ease;
}

.chip:hover{
  background: rgba(28,28,30,1);
  transform: translateY(-1px);
}
.chip-ico{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0.95;
}
.chip-ico svg{
  width: 14px;

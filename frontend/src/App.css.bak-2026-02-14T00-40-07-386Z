  white-space: nowrap;

  opacity: 0;
  pointer-events: none;

  transition: opacity 0.08s ease, transform 0.08s ease;
  z-index: 30;
}

/* setinha */
.icon-btn::before{
  content: "";
  position: absolute;
  left: 50%;
  bottom: calc(100% + 4px);
  transform: translateX(-50%);

  width: 8px;
  height: 8px;
  background: #ffffff;                 /* ðŸ”¥ setinha branca */
  border-left: 1px solid rgba(0,0,0,0.12);
  border-top: 1px solid rgba(0,0,0,0.12);

  opacity: 0;
  pointer-events: none;

  transition: opacity 0.08s ease;
  z-index: 29;
}

/* aparece IMEDIATAMENTE no hover/focus */
.icon-btn:hover::after,
.icon-btn:focus-visible::after{
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.icon-btn:hover::before,
.icon-btn:focus-visible::before{
  opacity: 1;

# Core AI Backend - Environment Variables (example)
# Copy to `.env` and fill values. Do NOT commit real secrets.

# App
APP_URL=http://localhost:5173
PORT=4000


# ===============================
# Closed Beta (Allowlist)
# ===============================
# Closed beta is ON by default. Set to 0 to disable without code changes.
# CLOSED_BETA_ENABLED=1
# Comma-separated lists (emails are normalized to lowercase)
# BETA_ADMIN_EMAIL=admin@getcoreai.io
# BETA_TEAM_EMAILS=dev1@getcoreai.io,dev2@getcoreai.io
# BETA_TESTER_EMAILS=tester1@gmail.com,tester2@gmail.com
# Optional cache TTL (ms) for beta allowlist lookups
# CLOSED_BETA_CACHE_TTL_MS=30000

# ===============================
# Queue / Cost guardrails (Launch defaults)
# ===============================
# In-memory, per-process queues separated by type+provider.
# These protect your provider rate limits and keep SSE stable under burst.
#
# Hard daily cost protection (global per process)
# DAILY_TEXT_LIMIT=20000
# DAILY_IMAGE_LIMIT=2000
#
# Defaults (can override per provider, ex: QUEUE_TEXT_OPENAI_RPM)
QUEUE_TEXT_CONCURRENCY=5
QUEUE_TEXT_RPM=60
QUEUE_TEXT_TIMEOUT_MS=60000

QUEUE_IMAGE_CONCURRENCY=2
QUEUE_IMAGE_RPM=20
QUEUE_IMAGE_TIMEOUT_MS=120000

# Backoff when providers return 429
# QUEUE_BACKOFF_BASE_MS=250
# QUEUE_BACKOFF_MAX_MS=10000

# Creative Studio: optional image-to-image input limits
# CREATIVE_INPUT_IMAGE_MAX_BYTES=10000000

# ===============================
# Attachments (Chat)
# ===============================
# Max number of media parts (images/PDFs) kept from the last user message.
# Set to 10 if you want *all* users/plans to be able to send up to 10 images/docs.
ATTACHMENTS_MAX_MEDIA_PARTS=10

# Attachment pipeline mode:
# - direct: do not extract attachments into text (send parts as-is)
# - hybrid: extract docs/PDFs into text and keep images as parts (recommended)
# - extractor: always extract docs/PDFs into text (images can still pass through)
# ATTACHMENTS_MODE=hybrid

# Docs/PDF extraction mode:
# - gemini: use Gemini as extractor (default; works out-of-the-box)
# - local: extract PDFs/DOCX locally (no extra API cost) (requires adding/installing deps)
# - none: never extract docs
# ATTACHMENTS_DOC_MODE=gemini
# If local doc extraction fails (when enabled), optionally fall back to Gemini:
# ATTACHMENTS_DOC_FALLBACK=gemini

# If a provider rejects `image_url` parts, optionally fall back to Gemini OCR and retry as text-only.
# Set to "none" to disable.
# ATTACHMENTS_IMAGE_FALLBACK=gemini

# Gemini model used for attachment extraction (OCR/docs).
# We recommend the cheapest/fastest extractor:
ATTACHMENT_EXTRACTOR_MODEL_ID=gemini-2.5 flash lite

# Local doc extraction limits (safety)
# ATTACHMENTS_DOC_MAX_BYTES=6000000
# ATTACHMENTS_PDF_MAX_PAGES=20
# ATTACHMENTS_DOC_MAX_CHARS_PER_FILE=18000
# ATTACHMENTS_DOC_MAX_TOTAL_CHARS=45000

# ===============================
# Chat context (cost + latency)
# ===============================
# Even if the frontend sends the entire conversation every request, the backend will
# build context from the DB and keep only a recent window when `conversationId` is present.
# This drastically reduces prompt tokens and improves latency.
CONVERSATION_CONTEXT_MAX_MESSAGES=24

# Optional: keep older messages as a compact persisted summary (best-effort background task).
CONVERSATION_SUMMARY_ENABLED=1
# CONVERSATION_SUMMARY_MODEL=gpt-5-nano
# CONVERSATION_SUMMARY_EVERY_N_MESSAGES=8
# CONVERSATION_SUMMARY_MAX_NEW_MESSAGES=40

# ===============================
# Persistent user memory (ChatGPT-style)
# ===============================
# Memory is injected up to the plan limit (MAX=300).
# Reduce cost by not running the memory extractor after *every* message during rapid chats.
# MEMORY_EXTRACTOR_MIN_INTERVAL_MS=15000
# MEMORY_EXTRACTOR_EXISTING_MAX=80

# ===============================
# Public URL (optional)
# ===============================
# If you have a public HTTPS domain for the backend, set this so providers can fetch
# input images by URL (some img2img providers won't reliably accept `data:` URIs).
# PUBLIC_API_URL=https://api.yourdomain.com

# ===============================
# OpenAI
# ===============================
OPENAI_API_KEY=COLE_AQUI
# Prompt caching (recommended)
# - OpenAI applies caching automatically where supported.
# - These knobs help increase cache reuse across requests (safe; does not change outputs).
OPENAI_PROMPT_CACHING=1
# Optional: a stable key to group cache across requests (defaults to `coreai:v1:<remoteModel>`)
# OPENAI_PROMPT_CACHE_KEY=coreai:v1
# Optional: depends on model/account; examples: "in-memory", "24h"
# OPENAI_PROMPT_CACHE_RETENTION=in-memory
# Optional (only needed if you want to force project-scoped access)
# OPENAI_PROJECT_ID=proj_...
# OPENAI_ORG_ID=org_...
# Optional model overrides (if OpenAI returns 404 model_not_found)
# OPENAI_GPT_52_PRO_REMOTE_MODEL=gpt-5.2-chat-latest
# OPENAI_GPT_51_REMOTE_MODEL=gpt-5.1
# OPENAI_GPT_5_MINI_REMOTE_MODEL=gpt-5-mini
# ===============================
# DeepSeek (OpenAI-compatible)
# ===============================
DEEPSEEK_API_KEY=COLE_AQUI
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional model overrides
DEEPSEEK_V32_REMOTE_MODEL=deepseek-chat
DEEPSEEK_R1_REMOTE_MODEL=deepseek-reasoner

# Auto-continue when DeepSeek response is cut by max tokens (finish_reason=length)
# DEEPSEEK_AUTO_CONTINUE=1
# DEEPSEEK_AUTO_CONTINUE_MAX_CALLS=2
# DEEPSEEK_AUTO_CONTINUE_TAIL_CHARS=1800

# ===============================
# Anthropic Claude
# ===============================
ANTHROPIC_API_KEY=COLE_AQUI
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# Prompt caching (recommended for long, stable system prompts)
ANTHROPIC_PROMPT_CACHING=1
# Optional: e.g. 5m, 1h (leave empty to use provider default)
# ANTHROPIC_PROMPT_CACHE_TTL=1h
# Optional model overrides
ANTHROPIC_CLAUDE_OPUS_46_REMOTE_MODEL=claude-opus-4-6
ANTHROPIC_CLAUDE_SONNET_46_REMOTE_MODEL=claude-sonnet-4-6
ANTHROPIC_CLAUDE_SONNET_45_REMOTE_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_CLAUDE_HAIKU_45_REMOTE_MODEL=claude-haiku-4-5-20251001

# ===============================
# Google (Gemini / Imagen)
# ===============================
GEMINI_API_KEY=COLE_AQUI
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Optional: OpenAI-compatible endpoint base (defaults to `${GEMINI_BASE_URL}/v1beta/openai`)
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional (text): Gemini Pro model overrides (model ids can vary by channel/account)
# GEMINI_31_PRO_REMOTE_MODEL=gemini-3.1-pro
# GEMINI_3_PRO_REMOTE_MODEL=gemini-3-pro-preview

# Creative Studio model overrides (optional)
GEMINI_NANO_BANANA_REMOTE_MODEL=gemini-2.5-flash-image
GEMINI_NANO_BANANA_2_REMOTE_MODEL=gemini-3.1-flash-image-preview
GEMINI_NANO_BANANA_PRO_REMOTE_MODEL=gemini-3-pro-image-preview

# ===============================
# xAI (Grok)
# ===============================
XAI_API_KEY=COLE_AQUI
XAI_BASE_URL=https://api.x.ai
GROK_42_REMOTE_MODEL=grok-4-2-rapid-reasoning
GROK_IMAGE_REMOTE_MODEL=grok-imagine-image
# GROK_IMAGE_MODEL_VARIANTS=grok-imagine-image,grok-2-image-1212
# Prompt caching (best-effort; auto-disables if the API rejects it)
GROK_PROMPT_CACHING=1
# GROK_PROMPT_CACHE_KEY=coreai:v1
# GROK_PROMPT_CACHE_RETENTION=

# ===============================
# Moonshot / Kimi (OpenAI-compatible)
# ===============================
MOONSHOT_API_KEY=COLE_AQUI
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# Optional alternative key name some setups use:
# KIMI_API_KEY=COLE_AQUI
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# Prompt caching (best-effort; auto-disables if the API rejects it)
MOONSHOT_PROMPT_CACHING=1
# MOONSHOT_PROMPT_CACHE_KEY=coreai:v1
# MOONSHOT_PROMPT_CACHE_RETENTION=

# ===============================
# Qwen / DashScope (OpenAI-compatible)
# ===============================
QWEN_API_KEY=COLE_AQUI
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Optional alternative key name some setups use:
# DASHSCOPE_API_KEY=COLE_AQUI
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Prompt caching (best-effort; auto-disables if the API rejects it)
QWEN_PROMPT_CACHING=1
# QWEN_PROMPT_CACHE_KEY=coreai:v1
# QWEN_PROMPT_CACHE_RETENTION=

# ===============================
# Perplexity (OpenAI-compatible)
# ===============================
PERPLEXITY_API_KEY=COLE_AQUI
PERPLEXITY_BASE_URL=https://api.perplexity.ai
# Prompt caching (best-effort; auto-disables if the API rejects it)
PERPLEXITY_PROMPT_CACHING=1
# PERPLEXITY_PROMPT_CACHE_KEY=coreai:v1
# PERPLEXITY_PROMPT_CACHE_RETENTION=

# ===============================
# Flux (OpenAI-compatible images proxy)
# ===============================
FLUX_API_KEY=COLE_AQUI
FLUX_BASE_URL=COLE_AQUI  # e.g. https://api.bfl.ai
FLUX_2_REMOTE_MODEL=flux-2
FLUX_2_PRO_REMOTE_MODEL=flux-2-pro
FLUX_IMAGE_RESPONSE_FORMAT=b64_json

# ===============================
# Ideogram (OpenAI-compatible images proxy)
# ===============================
IDEOGRAM_API_KEY=COLE_AQUI
IDEOGRAM_BASE_URL=COLE_AQUI
IDEOGRAM_3_REMOTE_MODEL=ideogram-3
IDEOGRAM_IMAGE_RESPONSE_FORMAT=b64_json
# Optional (img2img): higher values preserve identity more (1-100)
# IDEOGRAM_IMAGE_WEIGHT=80
# Optional: DEFAULT | TURBO | QUALITY (depends on gateway)
# IDEOGRAM_RENDERING_SPEED=DEFAULT
# Optional: only set if your gateway expects a specific enum (otherwise we use aspect_ratio derived from size)
# IDEOGRAM_RESOLUTION=
# Optional: when using the generate endpoint for remix-style flows
# IDEOGRAM_GENERATE_MODE=remix

# ===============================
# Seedream (OpenAI-compatible images proxy)
# ===============================
SEEDREAM_API_KEY=COLE_AQUI
SEEDREAM_BASE_URL=COLE_AQUI  # e.g. https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_45_REMOTE_MODEL=seedream-4-5-251128
# Optional: force an i2i/edit-capable model id when an input image is provided.
# SEEDREAM_I2I_REMOTE_MODEL=seededit-3-0-i2i-250628
# Optional: extra model ids to try for i2i (comma-separated)
# SEEDREAM_I2I_MODEL_VARIANTS=seedream-4-5-i2i-...,seededit-3-0-i2i-...
# Optional: recommended for editing
# SEEDREAM_EDIT_SIZE=adaptive
SEEDREAM_IMAGE_RESPONSE_FORMAT=b64_json
